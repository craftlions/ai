---
export const prerender = false;

import Logo from "../assets/logoWithText.svg";
import Pointer from "../assets/pointer.svg";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Splash">
	<div
		class="min-h-screen flex items-center justify-center bg-neutral-50 dark:bg-neutral-950 relative"
	>
		<div
			class="absolute top-4 z-10 px-4 py-2 rounded-lg bg-neutral-900/10 dark:bg-white/10 backdrop-blur-sm border border-neutral-200/50 dark:border-neutral-700/50"
		>
			<p
				class="text-xs text-neutral-500 dark:text-neutral-400 flex items-center gap-2"
			>
				<svg
					class="w-3.5 h-3.5"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z"
					/>
				</svg>
				Sound enabled
			</p>
		</div>
		<div class="flex flex-col items-center gap-3 z-10">
			<Logo
				transition:name="logo"
				class="w-72 h-72 text-current dark:text-white"
			/>
			<a
				id="enter-group"
				href="/bench"
				class="group flex flex-col items-center gap-1 cursor-pointer transition-transform duration-75 hover:scale-90 active:scale-75 select-none"
			>
				<Pointer
					class="w-8 h-8 text-neutral-600 dark:text-neutral-400 transition-colors group-hover:text-neutral-800 dark:group-hover:text-neutral-200"
				/>
				<span
					class="font-silkscreen text-xs text-neutral-600 dark:text-neutral-400 tracking-wider transition-colors group-hover:text-neutral-800 dark:group-hover:text-neutral-200"
				>
					ENTER
				</span>
			</a>
		</div>
	</div>
</Layout>

<script>
	const enterGroup = document.getElementById("enter-group");
	let audioContext: AudioContext | null = null;
	let audioUnlocked = false;
	let isHovering = false;

	function getAudioContext() {
		if (!audioContext) {
			audioContext = new (
				window.AudioContext || (window as any).webkitAudioContext
			)();
		}
		if (audioContext.state === "suspended") {
			audioContext.resume();
		}
		return audioContext;
	}

	function playClickSound() {
		if (!audioUnlocked) return;
		const ctx = getAudioContext();

		// Different click sound variations
		const sounds = [
			{ freq: 800, type: "square" as OscillatorType, duration: 0.05 },
			{ freq: 600, type: "square" as OscillatorType, duration: 0.04 },
			{ freq: 1000, type: "square" as OscillatorType, duration: 0.03 },
			{ freq: 700, type: "triangle" as OscillatorType, duration: 0.05 },
			{ freq: 900, type: "sawtooth" as OscillatorType, duration: 0.02 },
			{ freq: 500, type: "square" as OscillatorType, duration: 0.06 },
		];

		const sound = sounds[Math.floor(Math.random() * sounds.length)];

		const oscillator = ctx.createOscillator();
		const gainNode = ctx.createGain();

		oscillator.connect(gainNode);
		gainNode.connect(ctx.destination);

		oscillator.frequency.value = sound.freq;
		oscillator.type = sound.type;

		gainNode.gain.setValueAtTime(0.1, ctx.currentTime);
		gainNode.gain.exponentialRampToValueAtTime(
			0.01,
			ctx.currentTime + sound.duration,
		);

		oscillator.start(ctx.currentTime);
		oscillator.stop(ctx.currentTime + sound.duration);
	}

	// Unlock audio on first user interaction anywhere on the page
	function unlockAudio() {
		if (audioUnlocked) return;
		getAudioContext();
		audioUnlocked = true;
	}

	document.addEventListener("click", unlockAudio, { once: true });
	document.addEventListener("touchstart", unlockAudio, { once: true });
	document.addEventListener("keydown", unlockAudio, { once: true });

	enterGroup?.addEventListener("mouseenter", () => {
		if (!isHovering) {
			isHovering = true;
			playClickSound();
		}
	});

	enterGroup?.addEventListener("mouseleave", () => {
		isHovering = false;
	});

	enterGroup?.addEventListener("click", playClickSound);
</script>
